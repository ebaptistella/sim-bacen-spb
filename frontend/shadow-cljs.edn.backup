{:lein true

 :builds
 {:app {:target    :browser
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules   {:main {:init-fn com.github.ebaptistella.frontend.core/init}}
        :devtools  {:http-root "resources/public"
                    :http-port 8280
                    :watch-dir "resources/public"}}}}
